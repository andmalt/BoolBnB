    "compilerOptions": {
        "module": "ESNext",
        "moduleResolution": "Node",
        "target": "es2020",
        "jsx": "react-jsx",
        "strictNullChecks": true,
        "strictFunctionTypes": true,
        "strict": true,
        "sourceMap": true
